# ── .env.example ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is gitignored - never commit secrets.
#
#   cp .env.example .env
#
# ─────────────────────────────────────────────────────────────────────────────

# Docker Compose project name (used as image name prefix)
COMPOSE_PROJECT_NAME=myproject

# ── App settings ──────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=DEBUG
SECRET_KEY=change-me-in-production

# ── External API keys ─────────────────────────────────────────────────────────
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# STRIPE_SECRET_KEY=
# SENDGRID_API_KEY=

# ── Database (uncomment if using the db service in docker-compose.yml) ─────────
# POSTGRES_DB=appdb
# POSTGRES_USER=appuser
# POSTGRES_PASSWORD=
# DATABASE_URL=postgresql://appuser:password@db:5432/appdb

# ── Redis (uncomment if using the redis service) ───────────────────────────────
# REDIS_URL=redis://redis:6379/0

