{
  // Claude Code project-level settings.
  // See: https://docs.anthropic.com/en/docs/claude-code/settings

  "hooks": {

    // ── PostToolUse ──────────────────────────────────────────────────────────
    // Runs after Claude uses a tool. The example below auto-lints and formats
    // any Python file after Claude writes or edits it.
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd /workspace && ruff check --fix \"$CLAUDE_TOOL_RESULT_FILE_PATH\" 2>/dev/null; black \"$CLAUDE_TOOL_RESULT_FILE_PATH\" 2>/dev/null || true"
          }
        ]
      }
    ]

    // ── Notification ─────────────────────────────────────────────────────────
    // Fires when Claude sends a notification (e.g. needs your input).
    // Useful for desktop alerts on long-running tasks.
    // "Notification": [
    //   {
    //     "hooks": [
    //       {
    //         "type": "command",
    //         "command": "notify-send 'Claude Code' '$CLAUDE_NOTIFICATION_MESSAGE' 2>/dev/null || true"
    //       }
    //     ]
    //   }
    // ]

  },

  "mcpServers": {

